require "lxweb"
require "lxweb/lxweb_conn"
require "lxweb/lxweb_pipeline"
require "lxweb/lxweb_router"
require "lxweb/lxweb_controller"
require "lxweb/lxweb_view"
require "lxweb/lxweb_live"
require "lxweb/lxweb_live_socket"
require "lxweb/lxweb_router"

describe "lxweb_conn tests" do
  test "new/4 builds a Conn with defaults" do
    conn = %lxweb_conn:Conn{method: :get, path: "/hello"}
    assert conn.method == :get
    assert conn.path == "/hello"
    assert conn.status == 200
    assert conn.halted == false
  end

  test "put_status/2 updates status" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    conn2 = lxweb_conn:put_status(conn, 404)
    assert conn2.status == 404
  end

  test "put_resp_header/3 appends header" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    conn2 = lxweb_conn:put_resp_header(conn, "x-foo", "bar")
    assert conn2.resp_headers == [{"x-foo", "bar"}]
  end

  test "put_assign/3 sets assign" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    conn2 = lxweb_conn:put_assign(conn, :user, "alice")
    assert conn2.assigns[:user] == "alice"
  end

  test "halt/1 sets halted to true" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    conn2 = lxweb_conn:halt(conn)
    assert conn2.halted == true
  end
end

describe "lxweb_pipeline tests" do
  test "run/2 applies plugs in order" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    plug1 = fn(c, _opts :: list) -> lxweb_conn:put_assign(c, :step1, true) end
    plug2 = fn(c, _opts :: list) -> lxweb_conn:put_assign(c, :step2, true) end
    result = lxweb_pipeline:run(conn, [plug1, plug2])
    assert result.assigns.step1 == true
    assert result.assigns.step2 == true
  end

  test "run/2 stops at halted conn" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    plug1 = fn(c, _opts) -> lxweb_conn:halt(c) end
    plug2 = fn(c, _opts) -> lxweb_conn:put_assign(c, :reached, true) end
    result = lxweb_pipeline:run(conn, [plug1, plug2])
    assert result.halted == true
    assert result.assigns == %{}
  end

  test "put_secure_headers/2 adds security headers" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    result = lxweb_pipeline:put_secure_headers(conn, [])
    headers = for {n, _v} in result.resp_headers do n end
    assert "x-frame-options" in headers
    assert "x-content-type-options" in headers
  end
end

describe "lxweb_router tests" do
  test "match_path/2 matches static path" do
    assert lxweb_router:match_path("/users", "/users") == {:ok, %{}}
  end

  test "match_path/2 extracts path params" do
    result = lxweb_router:match_path("/users/:id", "/users/42")
    assert result == {:ok, %{id: "42"}}
  end

  test "match_path/2 returns :nomatch on mismatch" do
    assert lxweb_router:match_path("/users", "/posts") == :nomatch
  end

  test "strip_prefix/2 removes scope prefix" do
    assert lxweb_router:strip_prefix("/api", "/api/users") == "/users"
    assert lxweb_router:strip_prefix("/", "/users") == "/users"
  end
end

describe "lxweb_controller tests" do
  test "send_resp/3 sets status and body" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    result = lxweb_controller:send_resp(conn, 201, "created")
    assert result.status == 201
    assert result.body == "created"
  end

  test "redirect/2 sets 302 and location header" do
    conn = %lxweb_conn:Conn{method: :get, path: "/"}
    result = lxweb_controller:redirect(conn, "/new-path")
    assert result.status == 302
    location = for {n, v} in result.resp_headers when n == "location" do v end
    assert location == ["/new-path"]
  end

  test "get_param/2 returns param value" do
    conn = %lxweb_conn:Conn{method: :get, path: "/", params: %{id: "42"}}
    assert lxweb_controller:get_param(conn, :id) == "42"
    assert lxweb_controller:get_param(conn, :missing) == nil
  end
end
struct AssignsTest {
  a :: integer
  b :: integer
}
describe "lxweb_live Socket tests" do
  test "assign/2 merges assigns into socket" do
    socket = %lxweb_live_socket:Socket{assigns: %AssignsTest{}, live_module: nil, transport_pid: nil, connected: false}
    s2 = lxweb_live:assign(socket, %{count: 5})
    assert s2.assigns[:count] == 5
  end

  test "assign/2 merges without overwriting other keys" do
    socket = %lxweb_live_socket:Socket[AssignsTest]{assigns: %AssignsTest{a: 1}, live_module: nil, transport_pid: nil, connected: false}
    s2 = lxweb_live:assign(socket, %{b: 2})
    assert s2.assigns.a == 1
    assert s2.assigns.b == 2
  end

  test "diff/2 returns new html in v1" do
    result = lxweb_live:diff("<old>", "<new>")
    assert result == "<new>"
  end
end
