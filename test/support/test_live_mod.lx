def mount(_params :: map, _session :: map, socket :: map) do
  {:ok, %{socket | assigns: %{count: 0}}}
end
def render(assigns :: map) do
  "<div>#{assigns[:count]}</div>"
end
def handle_event("inc", _params :: map, socket :: map) do
  assigns = socket[:assigns]
  count = assigns[:count]
  {:noreply, %{socket | assigns: %{count: count + 1}}}
end
def handle_cast(_msg :: any, socket :: map) do
  {:noreply, socket}
end
def handle_info(_msg :: any, socket :: map) do
  {:noreply, socket}
end
def terminate(_reason :: any, _socket :: map) do
  :ok
end
