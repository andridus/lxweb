require "lxweb/lxweb_live_socket"
require "@erlang/erlang"

describe "lxweb_live_socket tests" do
  test "websocket_init/1 returns ok state" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:ok, _s2} = lxweb_live_socket:websocket_init(state)
  end

  test "websocket_info lv_joined encodes frame" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, frame}, _} = lxweb_live_socket:websocket_info({:lv_joined, "t", "<html>"}, state)
    assert erlang:is_binary(frame)
  end

  test "websocket_info lv_diff encodes frame" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, _}, _} = lxweb_live_socket:websocket_info({:lv_diff, "t", "<new>"}, state)
  end

  test "websocket_info lv_push_event encodes frame" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, _}, _} = lxweb_live_socket:websocket_info({:lv_push_event, "evt", %{x: 1}}, state)
  end

  test "websocket_info lv_redirect encodes frame" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, _}, _} = lxweb_live_socket:websocket_info({:lv_redirect, "/url"}, state)
  end

  test "websocket_info lv_flash encodes frame" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, _}, _} = lxweb_live_socket:websocket_info({:lv_flash, :info, "hi"}, state)
  end

  test "websocket_info lv_push_data encodes frame" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, _}, _} = lxweb_live_socket:websocket_info({:lv_push_data, :key, %{v: 1}}, state)
  end

  test "websocket_info heartbeat_timeout stops" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:stop, _} = lxweb_live_socket:websocket_info(:heartbeat_timeout, state)
  end

  test "websocket_handle heartbeat returns pong" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    data = "[1,\"t\",\"lv:heartbeat\",{}]"
    {:reply, {:text, _}, _} = lxweb_live_socket:websocket_handle({:text, data}, state)
  end

  test "websocket_handle unknown event returns ok" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    data = "[1,\"t\",\"lv:unknown\",{}]"
    {:ok, _} = lxweb_live_socket:websocket_handle({:text, data}, state)
  end

  test "websocket_handle non-text frame returns ok" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    {:ok, _} = lxweb_live_socket:websocket_handle(nil, state)
  end

  test "terminate/3 with nil live_pid returns ok" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: nil, transport_pid: nil, live_module: nil}
    :ok = lxweb_live_socket:terminate(:normal, nil, state)
  end

  test "terminate/3 with live_pid sends leave cast" do
    state = %lxweb_live_socket:WsState{topic: "t", live_pid: self(), transport_pid: nil, live_module: nil}
    :ok = lxweb_live_socket:terminate(:normal, nil, state)
  end

  test "encode_frame → websocket_handle round-trip" do
    state = %lxweb_live_socket:WsState{topic: "roundtrip", live_pid: nil, transport_pid: nil, live_module: nil}
    {:reply, {:text, frame}, _} = lxweb_live_socket:websocket_info({:lv_joined, "roundtrip", "<div>OK</div>"}, state)
    assert erlang:is_binary(frame)
    result = lxweb_live_socket:websocket_handle({:text, frame}, state)
    case result do
      {:reply, _, _} -> assert true
      {:ok, _} -> assert true
    end
  end
end
